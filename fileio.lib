;--------------------------------------------------------
;		Constants for FileIO;
;--------------------------------------------------------

DSKINT	equ	$e453 ;disk drive SIO handler
CIOMAIN equ	$e456 ;main CIO handler
CIOV	equ	$e456 ;alias for CIOMAIN
SIOINT	equ	$e459 ;main SIO handler
SIOV	equ	$e459 ;alias for SIOINT
SELFTST equ	$e471 ;SELF-TEST

;IOCB Block
IOCB	equ	$340 ;IO channels (8*16 bytes)
ICHID	equ	$340 ;device id - index in HATABS. $ff == not opened
ICDNO	equ	$341 ;# of device set by OS, eg. 2 for D2:
ICCMD	equ	$342 ;command for device
ICSTA	equ	$343 ;last operation status code
ICBUFA	equ	$344 ;address of device name to open
ICPTL	equ	$346 ;address of procedure call that sends one byte to device decreased by 1
ICBUFL	equ	$348 ;length of the buffer containing transmitted data
ICAUX1	equ	$34a ;auxilary byte #1, usually containing second parameter for OPEN command
ICAUX2	equ	$34b ;auxilary byte #2, third parameter for OPEN command
ICAUX3	equ	$34c ;remaining auxilary bytes
ICAUX4	equ	$34d
ICAUX5	equ	$34e
ICAUX6	equ	$34f

;HATABS
HATABS	equ	0x031A

;basic CIO commands (ICCOM)
CIO_open		equ 3	;OPEN command for IOCB channell
CIO_gettext		equ 5	;READ of text line
CIO_getdata		equ 7	;READ of binary data
CIO_puttext		equ 9	;WRITE of text line
CIO_putdata		equ 11	;WRITE of binary data
CIO_close    	equ 12	;CLOSE of IOCB channel
CIO_getstatus	equ 13	;READ of device status

;some dos specific XIO commands (ICCOM)
XIO_changedir	equ 41	;Change working directory (MyDOS)

;mode of operation (ICAX1) for OPEN
CIO_read     	equ 4  ;open to read
CIO_write     	equ 8  ;open to write
CIO_dir       	equ 6  ;get directory

;--------------------------------------------------------
;		Zero page variables for FileIO;
;--------------------------------------------------------
.zpvar	BankIndex	.word
.zpvar	AR_Temp		.byte
.zpvar	XR_Temp		.byte
.zpvar	YR_Temp		.byte
;--------------------------------------------------------
;		Other variables for FileIO;
;--------------------------------------------------------
.var	FileNamePtr	.word
.var	FileNameLng .byte
.var	TextPtr		.word
.var	LoadStatus	.byte	; $0 = failure, $1 = Success
Console_IOCB		.byte 0xFF
Temporary_Handler	.byte ' :',0x9B,0x00
VBXE_Handler		.byte 'S2:',0x9B,0x00

;--------------------------------------------------------
;		Common calls for FileIO
;--------------------------------------------------------

;--------------------------------------------------------
; Get_HATABS_Entry - retrives handler ID from HATABS table
; takes:
; A - HATABS offset from ICHID
; returns:
; A - letter identificator of the handler
Get_HATABS_Entry
	stx	XR_Temp
	tax
	lda	HATABS,x
	ldx	XR_Temp
	rts
	
;--------------------------------------------------------
;Find_Matching_IOCB - search for first matching IOCB
; takes:
; A - letter identificator of the handler to look for
; returns:
; X - relative offset to first free IOCB (IOCB number *16)
; Y - error code (126 - nonexistent device) if it fails

Find_Matching_IOCB
	sta	AR_Temp
	ldx	#0x00
	ldy	#0x01
Find_Matching_IOCB_l1
	lda	ICHID,x
	jsr	Get_HATABS_Entry
	cmp	AR_Temp		; compare device ID with the one searched
	beq	Find_Matching_IOCB_Found
	txa
	add	#0x10		; add IOCB structure length to x pointer, and try next channel
	tax
	bpl	Find_Matching_IOCB_l1
	ldy	#-126		; if fails, change error code to "NONEXISTENT DEVICE"	
Find_Matching_IOCB_Found
	rts

;--------------------------------------------------------
;Find_First_IOCB - search for first free IOCB
; returns:
; X - relative offset to first free IOCB (IOCB number *16)
; Y - error code (95 - too many channels open) if it fails
; 
; This piece of code comes from Polish Atariki page
; there are no references for its orgins

Find_First_IOCB
	ldx	#0x00		; start with channel #0
        ldy	#0x01		; set the error code to #1 - success
Find_First_IOCB_l1
	lda	ICHID,x		; get the device ID
        cmp	#0xff		; if equals to 0xff - channel is not opened
        beq	Find_First_IOCB_found
        txa
        add	#0x10		; add IOCB structure length to x pointer, and try next channel
        tax
        bpl	Find_First_IOCB_l1
        ldy	#-95       	;if fails, change error code to "TOO MANY CHANNELS OPEN"	
Find_First_IOCB_found
	rts

;--------------------------------------------------------
; PutLine - puts line of text pointed by TextPtr
; line should end with ENTER (0x9b)
PutLine
;	brk
	ldx	Console_IOCB
	cpx	#255
	bne	PutLine_IOCB_Open
	lda	#'E'
	jsr	Find_Matching_IOCB
	cpy	#1
	beq	PutLine_IOCB_Found
	lda	#'E'		; open through console handler
	ldy	#0		; Mode 0 - standard text console
	jsr	SetGraphicsMode
PutLine_IOCB_Open
PutLine_IOCB_Found
	lda	#CIO_puttext
	sta	iccmd,x
	lda	#255
	sta	icbufl,x
	lda	TextPtr
	sta	icbufa,x
	lda	TextPtr+1
	sta	icbufa+1,x
	jsr	ciov
PutLine_Error
	rts
	
;--------------------------------------------------------
; Set_Graphics_Mode - sets graphics mode
; takes:
; A - device handler (E, S, or V (S2))
; X - IOCB offset (IOCB channel number multiplied by 16)
; Y - mode to set
; returns:
; Y - error code (95 - too many channels open) if it fails

SetGraphicsMode
	jsr	Find_First_IOCB		; find first free IOCB
	cpy	#1
	bne	SetGraphicsMode_Error	; no more free IOCB
	cmp	#'V'
	beq	SetGraphicsMode_VBXE	; VBXE device handler is S2:, so we need special case for it :(
	sta	Temporary_Handler
	lda	#<Temporary_Handler
	sta	icbufa,x
	lda	#>Temporary_Handler
	sta	icbufa+1,x
SetGraphicsMode_Common
	tya
	sta	icaux2,x		; mode to obtain
	lda	#CIO_open	
	sta	iccmd,x
	lda	#CIO_read|CIO_write	; for both READ and WRITE operations
	sta	icaux1,x
	jsr	ciov
SetGraphicsMode_Error
	rts
SetGraphicsMode_VBXE
	lda	#<VBXE_Handler
	sta	icbufa,x
	lda	#>VBXE_Handler
	sta	icbufa+1,x
	jmp	SetGraphicsMode_Common
	
;--------------------------------------------------------
; LoadData - Loads file into banked memory
; bankindex - first bank number to load to
; This is slighty modified code provided by Mono (AtariArea)
; visit http://atariarea.krap.pl/forum/viewtopic.php?id=6781
; to see the original version
LoadData
	lda #1
	sta LoadStatus	; Indicate Failure
	jsr	Find_First_IOCB
	cpy	#1
	bne	LoadData_Error
	lda	#CIO_read
	sta	icaux1,x
	lda	#CIO_open
	sta	iccmd,x
	lda	FileNamePtr
	sta	icbufa,x
	lda	FileNamePtr+1
	sta	icbufa+1,x
	lda	FileNameLng
	sta	icbufl,x
	lda	#0
	sta	icbufl+1,x
	jsr	ciov
	bmi	LoadData_Error
	ldy	BankIndex
LoadData_l1
	tya
	ora	#0x80
	vbsta	VBXE_MA_BSEL
	;loading block of data to banked memory
	lda	#CIO_read
	sta	icaux1,x
	lda	#CIO_getdata		;getbyte
	sta	iccmd,x
	lda	<VBXE_WINDOW
	sta icbufa,x
	lda	>VBXE_WINDOW
	sta	icbufa+1,x
	lda	<0x1000
	sta	icbufl,x
	lda	>0x1000
	sta	icbufl+1,x
	jsr	ciov
	bmi	LoadData_Close
	inc	BankIndex
	ldy	BankIndex
	cpy	#127
	bcc	LoadData_l1
LoadData_Close
	php
	;at the end disable vbxe memory window
	lda	#0
	vbsta	VBXE_MA_BSEL
	lda	#CIO_close
	sta	iccmd,x
	jsr	ciov
	plp
	rts
LoadData_Error
	lda #0
	sta LoadStatus	; Indicate Failure
	rts
